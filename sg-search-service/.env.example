# Paste facilitator-provided Atlas URI
# Quote the value if it contains # or = characters (e.g. MONGODB_URI="mongodb+srv://...")
MONGODB_URI=

# Copy to .env in this folder — .env is gitignored
# Issuer must match the Okta authorization server used by the SPA
OKTA_ISSUER=https://{yourOktaDomain}/oauth2/default

# Audience for access-token JWT validation — use the authorization server audience
# (default server is usually api://default; NOT the SPA client ID)
OKTA_AUDIENCE=api://default

# Optional: return HTTP 403 when access token lacks this scope (leave unset to skip)
# OKTA_REQUIRED_SCOPE=
